<title>NEWRS Premium</title>

<style>
body { margin:0; font-family:'Segoe UI',sans-serif; background:#0f0f0f; color:white; overflow-x:hidden; }

/* Loader */
#loader { position:fixed; width:100%; height:100%; background:black; display:flex; align-items:center; justify-content:center; font-size:30px; z-index:9999; }

/* Cursor */
.cursor { width:20px; height:20px; border:2px solid #ff3c00; border-radius:50%; position:fixed; pointer-events:none; }

header { padding:40px; text-align:center; }
header img { width:100px; }

.hero {
 height:100vh;
 display:flex;
 flex-direction:column;
 justify-content:center;
 align-items:center;
 text-align:center;
 background:linear-gradient(45deg,#ff3c00,#000);
}
.hero h1 { font-size:50px; }

.btn { background:#ff3c00; padding:15px 30px; border-radius:30px; color:white; text-decoration:none; margin-top:20px; }

section { padding:80px 20px; text-align:center; }

.grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(250px,1fr)); gap:25px; }
.card { background:#1a1a1a; padding:20px; border-radius:20px; transition:0.4s; }
.card:hover { transform:translateY(-10px); box-shadow:0 0 20px #ff3c00; }
.card img { width:100%; border-radius:10px; }

.parallax { background:url('https://images.unsplash.com/photo-1492724441997-5dc865305da7') center/cover fixed; height:300px; display:flex; align-items:center; justify-content:center; font-size:30px; }

.whatsapp { position:fixed; bottom:20px; right:20px; background:#25D366; padding:15px; border-radius:50px; }

footer { background:#000; padding:20px; }
</style>
</head>

